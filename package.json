{
  "name": "@twilic/playground",
  "private": true,
  "version": "0.0.0",
  "description": "Playground for testing Twilic encoding and visualizing size savings.",
  "type": "module",
  "packageManager": "pnpm@10.18.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "sync-wasm": "node scripts/sync-twilic-wasm.mjs",
    "predev": "pnpm sync-wasm",
    "prebuild": "pnpm sync-wasm",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@cloudflare/kumo": "^2.2.1",
    "@msgpack/msgpack": "^3.1.3",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.4",
    "@twilic/core": "file:../twilic-js",
    "apache-arrow": "^21.1.0",
    "avsc": "^5.7.9",
    "bson": "^7.2.0",
    "buffer": "^6.0.3",
    "cbor-x": "^1.6.4",
    "flatbuffers": "^25.9.23",
    "protobufjs": "^7.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/protobufjs": "^6.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11"
  }
}
